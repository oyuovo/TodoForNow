{
  "name": "todo-web",
  "version": "0.0.1",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "prebuild:win": "cd ../JustTodoBE && mvn package -Dmaven.test.skip=true",
    "build:win": "set ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/ && set ELECTRON_BUILDER_BINARIES_MIRROR=https://cdn.npmmirror.com/binaries/electron-builder-binaries/ && npm run prebuild:win && vite build && electron-builder --win",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron": "electron .",
    "preview": "vite preview",
    "lint": "eslint . --ext .ts,.tsx,.vue --report-unused-disable-directives --max-warnings 0"
  },
  "dependencies": {
    "@iconify/vue": "^4.1.1",
    "@types/dompurify": "^3.0.5",
    "dompurify": "^3.3.1",
    "marked": "^12.0.0",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "concurrently": "^9.0.0",
    "electron": "^40.4.0",
    "electron-builder": "^26.8.1",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.31.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vue-eslint-parser": "^2.0.3",
    "vue-tsc": "^3.2.4",
    "wait-on": "^8.0.0"
  },
  "overrides": {
    "minimatch": "^10.2.1",
    "ajv": "^8.18.0",
    "tmp": "^0.2.4"
  },
  "build": {
    "appId": "com.oyuovo.justtodo",
    "productName": "JustTodo",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": ["dir"],
      "signAndEditExecutable": false
    },
    "files": ["dist/**/*", "electron/**/*"],
    "extraResources": [
      {
        "from": "../JustTodoBE/target/JustTodoBE-0.0.1-SNAPSHOT.jar",
        "to": "backend/JustTodoBE.jar"
      }
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
