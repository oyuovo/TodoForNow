# 复制此文件为 application.yaml 并填入实际配置
# cp application.yaml.example application.yaml

jwt:
  secret: your-jwt-secret-here
  expire-seconds: 604800  # 7 天

# 待办列表缓存 TTL 范围（秒），实际 TTL = base + random(0, range)
todo-cache:
  ttl-base-seconds: 300   # 5 分钟
  ttl-range-seconds: 600  # 随机加 0~10 分钟，即 5~15 分钟

spring:
  application:
    name: justtodobe
  datasource:
    url: jdbc:postgresql://localhost:5432/todo_db?currentSchema=public&sslmode=disable
    username: postgres
    password: your-database-password
    driver-class-name: org.postgresql.Driver
  data:
    redis:
      host: 192.168.12.130
      port: 6379
      password: your-redis-password  # 本地虚拟机密码，复制到 application.yaml 中填写
      database: 0
      timeout: 5000ms
mybatis-plus:
  type-aliases-package: justotodobe.entity
  type-handlers-package: justotodobe.utils

logging:
  level:
    justtodobe: debug
